{
  "name": "readme-doc-cli",
  "version": "0.1.0",
  "description": "Score README quality, detect missing sections, and generate improvement patches",
  "type": "module",
  "bin": {
    "readme-doctor": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "readme",
    "documentation",
    "linter",
    "quality",
    "cli",
    "changelog"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
